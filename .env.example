# ========================================
# Application Settings
# ========================================
APP_NAME="Gym Management System"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Ganti dengan value yang unique per project
# Generate dengan: php artisan key:generate
APP_KEY=

# ========================================
# Database - Central Database
# ========================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gym_central
DB_USERNAME=postgres
DB_PASSWORD=secret

# ========================================
# Database - Tenant Manager (spatie/laravel-tenancy)
# ========================================
# Database manager untuk create/drop tenant databases
TENANCY_DATABASE_MANAGER=postgres
TENANCY_CACHE_DRIVER=array

# ========================================
# Cache & Session
# ========================================
CACHE_DRIVER=array
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# ========================================
# Development - TablePlus Connection
# ========================================
# Host: localhost
# Port: 5432
# User: postgres
# Password: secret
# Database: gym_central