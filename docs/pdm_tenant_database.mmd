erDiagram
    %% ==========================================
    %% TENANT DATABASE — Per-Gym Instance
    %% 30 Tabel
    %% ==========================================

    %% ========== CORE: CABANG & STAF ==========

    branches {
        uuid id PK
        varchar branch_code "indexed"
        varchar name
        varchar address "nullable"
        varchar city "nullable"
        varchar phone "nullable"
        varchar email "nullable"
        varchar timezone "default Asia-Jakarta"
        boolean is_active "default true"
        date opened_at "nullable"
        json data "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    staffs {
        uuid id PK
        uuid branch_id FK "nullable, references branches.id SET NULL"
        varchar name
        varchar email UK
        varchar password
        varchar phone "nullable"
        text avatar "nullable"
        enum role "owner|staff"
        boolean is_active "default true"
        timestamp email_verified_at "nullable"
        varchar remember_token "nullable, 100 chars"
        timestamp last_login_at "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    staff_branches {
        uuid id PK
        uuid staff_id FK "references staffs.id CASCADE"
        uuid branch_id FK "references branches.id CASCADE"
        varchar role "default receptionist"
        boolean is_active "default true"
        timestamp joined_at "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    %% ========== MEMBERS ==========

    members {
        uuid id PK
        uuid home_branch_id FK "nullable, references branches.id SET NULL"
        varchar name
        varchar email UK "nullable"
        varchar phone "nullable, indexed"
        varchar emergency_contact "nullable"
        enum gender "nullable, male|female|other"
        date date_of_birth "nullable"
        varchar avatar "nullable"
        text address "nullable"
        varchar id_card_number "nullable, KTP"
        uuid qr_token UK "nullable"
        varchar password "nullable"
        timestamp email_verified_at "nullable"
        varchar remember_token "nullable, 100 chars"
        enum status "active|inactive|expired|frozen|banned"
        boolean is_active "default true"
        timestamp last_checkin_at "nullable"
        timestamp last_login_at "nullable"
        date member_since "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    %% ========== PENGATURAN CABANG ==========

    branch_settings {
        uuid id PK
        uuid branch_id FK "references branches.id CASCADE"
        enum setting_group "appearance|business|operational|membership|notification|security"
        varchar key "unique with branch_id"
        text value "nullable"
        enum type "string|integer|boolean|json|color"
        boolean is_public "default false"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    %% ========== ROLES & PERMISSIONS ==========

    roles {
        uuid id PK
        varchar name UK "eg branch_manager, cashier"
        varchar display_name
        text description "nullable"
        boolean is_active "default true"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    permissions {
        uuid id PK
        varchar permission_group "indexed, eg members, pos, reports"
        varchar name UK "format group.action"
        varchar display_name
        varchar action "indexed, view|manage"
        text description "nullable"
        int sort_order "default 0"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    role_permissions {
        uuid id PK
        uuid role_id FK "references roles.id CASCADE"
        uuid permission_id FK "references permissions.id CASCADE"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    %% ========== PLAN: MEMBERSHIP ==========

    membership_plans {
        uuid id PK
        uuid branch_id FK "nullable, references branches.id SET NULL"
        enum access_type "single_branch|cross_branch"
        enum approval_status "draft|pending|approved|rejected"
        varchar name
        varchar category
        text description "nullable"
        varchar color "nullable"
        int sort_order "default 0"
        decimal price "12-2"
        varchar currency "default IDR"
        int duration
        enum duration_unit "day|week|month|year"
        int loyalty_points_reward "default 0"
        int max_sharing_members "default 0"
        boolean unlimited_checkin "default false"
        int checkin_quota_per_month "nullable"
        boolean unlimited_sold "default true"
        int total_quota "nullable"
        boolean always_available "default true"
        date available_from "nullable"
        date available_until "nullable"
        json checkin_schedule "nullable"
        boolean is_active "default true"
        uuid created_by "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    plan_branch_access {
        bigint id PK "auto-increment"
        uuid plan_id FK "references membership_plans.id CASCADE"
        uuid branch_id FK "references branches.id CASCADE"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    %% ========== PLAN: KELAS ==========

    class_plans {
        uuid id PK
        varchar name
        varchar category "nullable"
        text description "nullable"
        varchar color "nullable"
        int sort_order "default 0"
        decimal price "12-2 default 0"
        varchar currency "default IDR"
        int max_capacity
        int minutes_per_session
        uuid branch_id "nullable, no FK constraint"
        enum access_type "all_branches|single_branch"
        boolean unlimited_monthly_session "default false"
        int monthly_quota "nullable"
        boolean unlimited_daily_session "default false"
        int daily_quota "nullable"
        boolean always_available "default true"
        date available_from "nullable"
        date available_until "nullable"
        boolean is_active "default true"
        uuid created_by "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    membership_plan_class_plan {
        uuid membership_plan_id PK "composite PK, references membership_plans.id CASCADE"
        uuid class_plan_id PK "composite PK, references class_plans.id CASCADE"
        boolean unlimited_session "default false"
        int monthly_quota_override "nullable"
        int daily_quota_override "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    %% ========== PLAN: PERSONAL TRAINING ==========

    pt_session_plans {
        uuid id PK
        varchar name
        varchar category
        text description "nullable"
        varchar color "nullable"
        int sort_order "default 0"
        decimal price "12-2"
        varchar currency "default IDR"
        int duration
        enum duration_unit "day|week|month|year"
        int minutes_per_session
        int total_sessions "default 1"
        int loyalty_points_reward "default 0"
        uuid branch_id "nullable, no FK constraint"
        boolean unlimited_sold "default true"
        int total_quota "nullable"
        boolean always_available "default true"
        date available_from "nullable"
        date available_until "nullable"
        boolean is_active "default true"
        uuid created_by "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    %% ========== FASILITAS ==========

    facilities {
        uuid id PK
        varchar name
        varchar category "nullable"
        text description "nullable"
        varchar color "nullable"
        int sort_order "default 0"
        decimal price "12-2 default 0"
        varchar currency "default IDR"
        int minutes_per_session
        int capacity "default 1"
        enum access_type "public|private"
        uuid branch_id "nullable, no FK constraint"
        json operational_hours "nullable"
        boolean always_available "default true"
        date available_from "nullable"
        date available_until "nullable"
        boolean is_active "default true"
        uuid created_by "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    %% ========== PRODUK & STOK ==========

    products {
        uuid id PK
        varchar name
        varchar code UK "nullable"
        varchar category
        text description "nullable"
        varchar color "nullable"
        int sort_order "default 0"
        uuid branch_id "nullable, no FK constraint"
        decimal selling_price "12-2"
        decimal cost_price "12-2 default 0"
        varchar currency "default IDR"
        int stock "default 0, indexed"
        int min_stock "default 0"
        varchar unit "default pcs"
        varchar image "nullable"
        boolean is_active "default true"
        uuid created_by "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    stock_movements {
        uuid id PK
        uuid product_id "indexed with created_at"
        uuid branch_id "nullable, indexed with created_at"
        enum type "purchase|sale|adjustment|return|transfer"
        int qty_before
        int qty_change "positive=in negative=out"
        int qty_after
        text notes "nullable"
        uuid reference_id "nullable, polymorphic"
        varchar reference_type "nullable, polymorphic"
        uuid created_by "nullable"
        timestamp created_at "useCurrent, no updated_at"
    }

    %% ========== OPERASIONAL: MEMBERSHIP ==========

    memberships {
        uuid id PK
        uuid member_id FK "references members.id CASCADE"
        uuid membership_plan_id FK "references membership_plans.id CASCADE"
        uuid branch_id FK "nullable, references branches.id SET NULL"
        uuid tenant_invoice_id FK "nullable, references tenant_invoices.id SET NULL"
        varchar last_transaction_id "nullable"
        date start_date
        date end_date "nullable, null=lifetime"
        varchar status "active|expired|frozen|cancelled"
        boolean unlimited_checkin "default false"
        int remaining_checkin_quota "nullable"
        int total_checkins "default 0"
        date frozen_at "nullable"
        date frozen_until "nullable"
        int freeze_days_used "default 0"
        text notes "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    %% ========== OPERASIONAL: CHECK-IN ==========

    check_ins {
        uuid id PK
        uuid member_id FK "references members.id CASCADE"
        uuid branch_id FK "references branches.id CASCADE"
        uuid membership_id FK "nullable, references memberships.id SET NULL"
        timestamp checked_in_at "indexed"
        enum status "success|failed"
        varchar notes "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    %% ========== OPERASIONAL: JADWAL KELAS ==========

    class_schedules {
        uuid id PK
        uuid class_plan_id FK "references class_plans.id CASCADE"
        uuid instructor_id FK "references staffs.id RESTRICT"
        uuid branch_id FK "references branches.id CASCADE"
        date date "indexed"
        time start_at
        time end_at
        enum status "scheduled|ongoing|completed|cancelled"
        uint max_capacity "nullable, override dari plan"
        uint total_booked "default 0"
        uint total_attended "default 0"
        enum class_type "membership_only|public|private"
        varchar cancelled_reason "nullable"
        text notes "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    class_attendances {
        uuid id PK
        uuid class_schedule_id FK "references class_schedules.id CASCADE"
        uuid member_id FK "references members.id CASCADE"
        uuid checked_in_by FK "nullable, references staffs.id SET NULL"
        enum status "booked|attended|cancelled|no_show"
        timestamp booked_at "nullable"
        timestamp attended_at "nullable"
        timestamp cancelled_at "nullable"
        text notes "nullable"
        uuid tenant_invoice_id FK "nullable, references tenant_invoices.id SET NULL"
        enum payment_status "free|pending|paid"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    %% ========== OPERASIONAL: PERSONAL TRAINING ==========

    pt_packages {
        uuid id PK
        uuid member_id FK "references members.id"
        uuid pt_session_plan_id FK "references pt_session_plans.id"
        uuid tenant_invoice_id "nullable, link to payment"
        uuid branch_id "branch where purchased"
        int total_sessions
        int used_sessions "default 0"
        enum status "pending|active|completed|expired|cancelled"
        date purchased_at
        date activated_at "nullable"
        date expired_at "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    pt_sessions {
        uuid id PK
        uuid pt_package_id FK "references pt_packages.id"
        uuid member_id "denormalized for query"
        uuid trainer_id "staff trainer ID"
        uuid branch_id
        date date
        time start_at
        time end_at
        enum status "requested|scheduled|ongoing|completed|cancelled|rejected"
        text notes "nullable"
        text cancelled_reason "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
        timestamp deleted_at "softDeletes"
    }

    pt_session_attendances {
        uuid id PK
        uuid pt_session_id FK "references pt_sessions.id"
        uuid member_id
        uuid pt_package_id
        enum status "scheduled|attended|cancelled|no_show"
        timestamp attended_at "nullable"
        uuid recorded_by "nullable, staff who checked in"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    %% ========== OPERASIONAL: FASILITAS ==========

    facility_bookings {
        uuid id PK
        uuid facility_id FK "references facilities.id CASCADE"
        uuid member_id FK "references members.id CASCADE"
        uuid branch_id "nullable"
        date date
        time start_time
        time end_time "auto-calculated"
        enum status "booked|completed|cancelled|no_show"
        enum payment_status "free|pending|paid|expired|failed"
        uuid tenant_invoice_id "nullable, link to invoice"
        uuid booked_by "nullable, staff ID"
        text notes "nullable"
        varchar cancelled_reason "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    %% ========== BILLING: INVOICE & PAYMENT ==========

    tenant_invoices {
        uuid id PK
        uuid tenant_id "indexed"
        uuid member_id FK "nullable, references members.id SET NULL"
        varchar guest_name "nullable"
        varchar guest_phone "nullable, 20 chars"
        varchar guest_email "nullable"
        uuid branch_id FK "references branches.id CASCADE"
        varchar invoice_number UK
        varchar external_reference "nullable"
        decimal subtotal "15-2"
        decimal tax "15-2 default 0"
        decimal total_amount "15-2"
        varchar currency "default IDR, 10 chars"
        varchar payment_gateway "default midtrans"
        varchar payment_method "nullable"
        varchar transaction_id "nullable"
        enum status "pending|paid|failed|expired|canceled"
        timestamp issued_at "nullable"
        timestamp due_date "nullable"
        timestamp paid_at "nullable"
        json gateway_response "nullable"
        text notes "nullable"
        uuid created_by "nullable, staff/cashier"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    tenant_invoice_items {
        uuid id PK
        uuid tenant_invoice_id FK "references tenant_invoices.id CASCADE"
        varchar item_type "polymorphic type"
        uuid item_id "polymorphic ID"
        varchar item_name
        int quantity "default 1"
        decimal unit_price "15-2"
        decimal total_price "15-2"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    tenant_payments {
        uuid id PK
        uuid tenant_invoice_id FK "references tenant_invoices.id CASCADE"
        varchar provider "default midtrans"
        varchar payment_type "nullable, qris|bank_transfer"
        varchar transaction_id "nullable, indexed"
        varchar order_id "indexed"
        decimal gross_amount "15-2"
        enum status "pending|success|failed|expired|refund"
        json raw_response "nullable"
        timestamp paid_at "nullable"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    %% ========== NOTIFIKASI ==========

    tenant_notifications {
        uuid id PK
        uuid branch_id FK "nullable, references branches.id CASCADE"
        uuid staff_id FK "nullable, references staffs.id SET NULL"
        varchar type "eg new_member, pos_transaction"
        varchar title
        text message
        boolean is_read "default false"
        timestamp created_at "nullable"
        timestamp updated_at "nullable"
    }

    %% ========== AUTH TOKENS ==========

    staff_password_reset_tokens {
        varchar email PK
        varchar token
        timestamp created_at "nullable"
    }

    member_password_reset_tokens {
        varchar email PK
        varchar token
        timestamp created_at "nullable"
    }

    %% ==========================================
    %% RELASI — Cabang & Staf
    %% ==========================================

    branches |o--o{ staffs : "cabang utama"
    staffs ||--o{ staff_branches : "ditugaskan ke"
    branches ||--o{ staff_branches : "memiliki staf"
    branches ||--o{ branch_settings : "pengaturan"

    %% ==========================================
    %% RELASI — Roles & Permissions
    %% ==========================================

    roles ||--o{ role_permissions : "memiliki"
    permissions ||--o{ role_permissions : "diberikan ke"

    %% ==========================================
    %% RELASI — Member
    %% ==========================================

    branches |o--o{ members : "cabang utama"
    members ||--o{ memberships : "mendaftar"
    members ||--o{ check_ins : "check-in"
    members ||--o{ class_attendances : "menghadiri kelas"
    members ||--o{ pt_packages : "membeli paket PT"
    members ||--o{ facility_bookings : "memesan fasilitas"
    members |o--o{ tenant_invoices : "ditagih"

    %% ==========================================
    %% RELASI — Membership Plan
    %% ==========================================

    membership_plans ||--o{ memberships : "digunakan"
    membership_plans ||--o{ membership_plan_class_plan : "menyertakan kelas"
    membership_plans ||--o{ plan_branch_access : "berlaku di"
    branches |o--o{ membership_plans : "milik cabang"
    branches ||--o{ plan_branch_access : "diakses oleh plan"

    %% ==========================================
    %% RELASI — Class Plan & Schedule
    %% ==========================================

    class_plans ||--o{ membership_plan_class_plan : "termasuk dalam membership"
    class_plans ||--o{ class_schedules : "dijadwalkan"
    staffs ||--o{ class_schedules : "mengajar"
    branches ||--o{ class_schedules : "lokasi kelas"
    class_schedules ||--o{ class_attendances : "dihadiri"
    staffs |o--o{ class_attendances : "mencatat kehadiran"

    %% ==========================================
    %% RELASI — Personal Training
    %% ==========================================

    pt_session_plans ||--o{ pt_packages : "dibeli sebagai paket"
    pt_packages ||--o{ pt_sessions : "dijadwalkan sesi"
    pt_sessions ||--o{ pt_session_attendances : "dicatat kehadiran"

    %% ==========================================
    %% RELASI — Fasilitas
    %% ==========================================

    facilities ||--o{ facility_bookings : "dipesan"

    %% ==========================================
    %% RELASI — Membership & Check-in
    %% ==========================================

    memberships |o--o{ check_ins : "menggunakan"
    branches ||--o{ memberships : "berlokasi"
    branches ||--o{ check_ins : "lokasi check-in"

    %% ==========================================
    %% RELASI — Billing
    %% ==========================================

    branches ||--o{ tenant_invoices : "penagihan"
    tenant_invoices ||--o{ tenant_invoice_items : "berisi item"
    tenant_invoices ||--o{ tenant_payments : "dibayar"
    tenant_invoices |o--o{ memberships : "pembayaran membership"
    tenant_invoices |o--o{ class_attendances : "pembayaran kelas"

    %% ==========================================
    %% RELASI — Notifikasi
    %% ==========================================

    branches |o--o{ tenant_notifications : "notifikasi cabang"
    staffs |o--o{ tenant_notifications : "memicu notifikasi"
