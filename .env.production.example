# =============================================
# GYMFIT Production Environment Variables
# =============================================

# =============================================

# ========================================
# Application
# ========================================
APP_NAME="Gymfit"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GENERATE_DENGAN_php_artisan_key_generate
APP_URL=https://gymfit.id

# ========================================
# Database
# ========================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gym_central
DB_USERNAME=postgres
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT

# ========================================
# Tenancy
# ========================================
TENANCY_DATABASE_MANAGER=postgres
TENANCY_CACHE_DRIVER=database
TENANT_BASE_DOMAIN=gymfit.id

# ========================================
# Cache & Session
# ========================================
CACHE_STORE=database
CACHE_DRIVER=database
SESSION_DRIVER=file
SESSION_DOMAIN=.gymfit.id
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=sync

# ========================================
# Sanctum — Cookie Auth cross-subdomain
# ========================================
SANCTUM_STATEFUL_DOMAINS=gymfit.id,*.gymfit.id

# ========================================
# Frontend
# ========================================
FRONTEND_PORT=
NEXT_PUBLIC_ROOT_DOMAIN=gymfit.id
NEXT_PUBLIC_API_URL=https://gymfit.id/api

# ========================================
# Caddy / Cloudflare
# ========================================
CLOUDFLARE_API_TOKEN=GANTI_DENGAN_CF_TOKEN

# ========================================
# Mail (Resend SMTP Production)
# ========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=re_masukkan_api_key_resend_kamu
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@gymfit.id
MAIL_FROM_NAME="Gymfit"

# ========================================
# Google OAuth (opsional)
# ========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://gymfit.id/api/tenant-auth/google/callback
GOOGLE_MEMBER_REDIRECT_URL=https://gymfit.id/api/tenant-auth/member/google/callback

# ========================================
# Cloudflare R2 — Product Image Storage
# Setup: https://dash.cloudflare.com/ → R2 → Create bucket "gymfit-assets"
# 1. Buat bucket "gymfit-assets" di Cloudflare R2
# 2. Buat API Token R2 (R2 Admin Read & Write)
# 3. Tambah custom domain cdn.gymfit.id di settings bucket
# ========================================
CLOUDFLARE_R2_ACCESS_KEY_ID=GANTI_DENGAN_R2_ACCESS_KEY
CLOUDFLARE_R2_SECRET_ACCESS_KEY=GANTI_DENGAN_R2_SECRET_KEY
CLOUDFLARE_R2_BUCKET=gymfit-assets
CLOUDFLARE_R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_URL=https://cdn.gymfit.id

# ========================================
# Midtrans Payment Gateway — PRODUCTION
# Dashboard: https://dashboard.midtrans.com
# Settings → Access Keys → pastikan toggle "Production" aktif
# PERHATIAN: Key production BERBEDA dengan key sandbox!
# Prefix production: Mid-server-xxx (tanpa SB-)
# Prefix sandbox:    SB-Mid-server-xxx
# ========================================
MIDTRANS_SERVER_KEY=Mid-server-GANTI_DENGAN_PRODUCTION_SERVER_KEY
MIDTRANS_CLIENT_KEY=Mid-client-GANTI_DENGAN_PRODUCTION_CLIENT_KEY
MIDTRANS_IS_PRODUCTION=true
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true
FRONTEND_URL=https://gymfit.id
