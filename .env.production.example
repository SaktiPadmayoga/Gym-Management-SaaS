# =============================================
# GYMFIT Production Environment Variables
# =============================================

# =============================================

# ========================================
# Application
# ========================================
APP_NAME="Gymfit"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GENERATE_DENGAN_php_artisan_key_generate
APP_URL=https://gymfit.id

# ========================================
# Database
# ========================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gym_central
DB_USERNAME=postgres
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT

# ========================================
# Tenancy
# ========================================
TENANCY_DATABASE_MANAGER=postgres
TENANCY_CACHE_DRIVER=database

# ========================================
# Cache & Session
# ========================================
CACHE_STORE=database
CACHE_DRIVER=database
SESSION_DRIVER=file
SESSION_DOMAIN=.gymfit.id
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=sync

# ========================================
# Sanctum — Cookie Auth cross-subdomain
# ========================================
SANCTUM_STATEFUL_DOMAINS=gymfit.id,*.gymfit.id

# ========================================
# Frontend
# ========================================
FRONTEND_PORT=
NEXT_PUBLIC_ROOT_DOMAIN=gymfit.id
NEXT_PUBLIC_API_URL=https://gymfit.id/api

# ========================================
# Caddy / Cloudflare
# ========================================
CLOUDFLARE_API_TOKEN=GANTI_DENGAN_CF_TOKEN

# ========================================
# Mail (Resend SMTP Production)
# ========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=re_masukkan_api_key_resend_kamu
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@gymfit.id
MAIL_FROM_NAME="Gymfit"

# ========================================
# Google OAuth (opsional)
# ========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://gymfit.id/api/tenant-auth/google/callback
GOOGLE_MEMBER_REDIRECT_URL=https://gymfit.id/api/tenant-auth/member/google/callback
