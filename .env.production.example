# =============================================
# Fitnice Production Environment Variables
# =============================================
# CATATAN: File ini HANYA template referensi.
# Di production, isi semua value melalui Komodo Environment Variables.
# JANGAN commit file ini dengan value asli ke GitHub!
# =============================================

# ========================================
# Application
# ========================================
APP_NAME="Fitnice"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GENERATE_DENGAN_php_artisan_key_generate
APP_URL=https://fitnice.com

# ========================================
# Database
# ========================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gym_central
DB_USERNAME=postgres
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT

# ========================================
# Tenancy
# ========================================
TENANCY_DATABASE_MANAGER=postgres
TENANCY_CACHE_DRIVER=database

# ========================================
# Cache & Session
# ========================================
CACHE_STORE=database
CACHE_DRIVER=database
SESSION_DRIVER=file
SESSION_DOMAIN=.fitnice.com
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=sync

# ========================================
# Sanctum — Cookie Auth cross-subdomain
# ========================================
SANCTUM_STATEFUL_DOMAINS=fitnice.com,*.fitnice.com

# ========================================
# Frontend
# ========================================
FRONTEND_PORT=
NEXT_PUBLIC_ROOT_DOMAIN=fitnice.com
NEXT_PUBLIC_API_URL=https://fitnice.com/api

# ========================================
# Caddy / Cloudflare
# ========================================
CLOUDFLARE_API_TOKEN=GANTI_DENGAN_CF_TOKEN

# ========================================
# Mail (Mailtrap / SMTP Production)
# ========================================
MAIL_MAILER=smtp
MAIL_HOST=live.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@fitnice.com
MAIL_FROM_NAME="Fitnice"

# ========================================
# Google OAuth (opsional)
# ========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://fitnice.com/api/tenant-auth/google/callback
GOOGLE_MEMBER_REDIRECT_URL=https://fitnice.com/api/tenant-auth/member/google/callback
