# =============================================
# Caddyfile — Gymfit Production
# =============================================
# Mode: HTTP only (port 80 di dalam container)
# SSL ditangani oleh reverse proxy utama VPS
# Caddy bertugas routing wildcard subdomain tenant
# =============================================

{
	auto_https off
}

:80 {
	# Semua request ke Nginx internal
	reverse_proxy nginx:80 {
		# Forward real client info ke Nginx/app
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
