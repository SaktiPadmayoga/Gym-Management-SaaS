# =============================================
# Caddyfile — Gymfit Production
# =============================================
# Mode: HTTP only (port 80 di dalam container)
# SSL ditangani oleh reverse proxy utama VPS
# Caddy bertugas routing wildcard subdomain tenant
# =============================================

gymfit.id, *.gymfit.id {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	reverse_proxy nginx:80 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
